--// SERVICES
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

local player = Players.LocalPlayer

--// WEBHOOK
local WEBHOOK_URL = "https://discord.com/api/webhooks/1477439178672439297/86hcA3t2RhwpGUO_uaQ2_3pWfmx_xH9ABCUoBtwgWpyUcNtqdKT43603BfqUlvXJy_Jr"

local sentCache = {}

--========================
-- WEBHOOK FUNCTION
--========================
local function SendWebhook(userName, modelName, folderType)

	local embedColor = 16753920 -- default Divine (orange)

	if folderType == "Infinity" then
		embedColor = 255 -- biru tua
	elseif folderType == "Divine" then
		embedColor = 16753920 -- orange
	end

	local data = {
		embeds = {
			{
				title = "In server " .. userName .. " New Spawn Brainrot",

				description =
					"NAME BRAINROT: [" .. modelName .. "]\n\n" ..
					"Rarity: [" .. folderType .. "]\n\n" ..
					"ESCAPE TSUNAMI FOR BRAINROT\n\nSCRIPT BY **HENDAR**",

				color = embedColor,

				footer = {
					text = "THANKS YOU 😘 | WEBHOOK ONLY DIVINE & INFINITY"
				}
			}
		}
	}

	local json = HttpService:JSONEncode(data)

	pcall(function()
		request({
			Url = WEBHOOK_URL,
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json"
			},
			Body = json
		})
	end)
end

--========================
-- MONITOR FUNCTION
--========================
local function MonitorFolder(folderName)
	task.spawn(function()
		while true do
			
			local folder = workspace.ActiveBrainrots:FindFirstChild(folderName)
			
			if folder then
				for _, model in pairs(folder:GetChildren()) do
					if model:IsA("Model") then
						
						for _, inner in pairs(model:GetChildren()) do
							if inner:IsA("Model") then
								
								if not sentCache[inner.Name] then
									sentCache[inner.Name] = true
									SendWebhook(player.Name, inner.Name, folderName)
								end
								
							end
						end
						
					end
				end
			end
			
			task.wait(2)
		end
	end)
end

-- START
MonitorFolder("Infinity")
MonitorFolder("Divine")
